{
  "name": "@redux/shared",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./models": {
      "types": "./dist/models/index.d.ts",
      "default": "./src/models/index.ts"
    }
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsc",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@redux/models": "workspace:*",
    "@silo-storage/mime-types": "catalog:"
  },
  "devDependencies": {
    "@redux/eslint-config": "workspace:*",
    "@redux/prettier-config": "workspace:*",
    "@redux/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:"
  },
  "prettier": "@redux/prettier-config"
}
