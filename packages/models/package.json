{
  "name": "@redux/models",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./anthropic": {
      "types": "./dist/generated/anthropic.d.ts",
      "default": "./src/generated/anthropic.ts"
    },
    "./google": {
      "types": "./dist/generated/google.d.ts",
      "default": "./src/generated/google.ts"
    },
    "./openai": {
      "types": "./dist/generated/openai.d.ts",
      "default": "./src/generated/openai.ts"
    },
    "./openrouter": {
      "types": "./dist/generated/openrouter.d.ts",
      "default": "./src/generated/openrouter.ts"
    },
    "./workersai": {
      "types": "./dist/generated/workersai.d.ts",
      "default": "./src/generated/workersai.ts"
    }
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsc",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "models:generate": "tsx scripts/generate-models.ts",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false && tsc -p tsconfig.scripts.json --noEmit"
  },
  "devDependencies": {
    "@redux/eslint-config": "workspace:*",
    "@redux/prettier-config": "workspace:*",
    "@redux/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  },
  "prettier": "@redux/prettier-config"
}
