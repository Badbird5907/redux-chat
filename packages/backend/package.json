{
  "name": "@redux/backend",
  "private": true,
  "type": "module",
  "exports": {
    "./convex/_generated/server": {
      "types": "./convex/_generated/server.d.ts",
      "default": "./convex/_generated/server.js"
    },
    "./convex/_generated/dataModel": {
      "types": "./convex/_generated/dataModel.d.ts",
      "default": "./convex/_generated/dataModel.js"
    },
    "./convex/_generated/api": {
      "types": "./convex/_generated/api.d.ts",
      "default": "./convex/_generated/api.js"
    },
    "./convex/auth": {
      "types": "./convex/auth.ts",
      "default": "./convex/auth.ts"
    },
    "./convex/auth.config": {
      "types": "./convex/auth.config.ts",
      "default": "./convex/auth.config.ts"
    },
    "./env": {
      "types": "./convex/env.ts",
      "default": "./convex/env.ts"
    },
    "./convex/functions": {
      "types": "./convex/functions/index.ts",
      "default": "./convex/functions/index.ts"
    },
    "./convex/betterAuth/audit_log/client": {
      "types": "./convex/betterAuth/audit_log/client.ts",
      "default": "./convex/betterAuth/audit_log/client.ts"
    }
  },
  "license": "MIT",
  "scripts": {
    "dev": "dotenv -e ../../.env -- convex dev",
    "convex": "dotenv -e ../../.env -- convex",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "format": "prettier --check . --ignore-path ../../.gitignore --ignore-path .prettierignore",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "auth:generate": "dotenv -e ../../.env -- pnpx @better-auth/cli generate --config scripts/auth-cli.ts --output convex/betterAuth/schema.ts",
    "typecheck": "tsc --noEmit",
    "build:app": "cd ../.. && pnpm build"
  },
  "dependencies": {
    "@ai-sdk/google-vertex": "5.0.0",
    "@better-auth/core": "^1.6.9",
    "@convex-dev/better-auth": "^0.12.1",
    "@convex-dev/crons": "^0.2.0",
    "@convex-dev/stripe": "^0.1.4",
    "@openrouter/ai-sdk-provider": "6.0.0-alpha.1",
    "@redux/shared": "workspace:*",
    "@redux/types": "workspace:*",
    "@silo-storage/sdk-core": "catalog:",
    "@t3-oss/env-core": "^0.13.11",
    "ai": "7.0.2",
    "better-auth": "catalog:",
    "buffer": "^6.0.3",
    "convex": "^1.36.1",
    "convex-helpers": "^0.1.115",
    "nanoid": "^5.1.9",
    "stripe": "^22.1.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@edge-runtime/vm": "catalog:",
    "@redux/eslint-config": "workspace:*",
    "@redux/prettier-config": "workspace:*",
    "@redux/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "convex-test": "^0.0.51",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "prettier": "@redux/prettier-config"
}
